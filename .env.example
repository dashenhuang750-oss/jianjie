# Copy this file to .env, then fill in your own key.
# Do not commit .env to a public repository.
DEEPSEEK_API_KEY=

# DeepSeek OpenAI-compatible chat API settings.
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Chat quota protection. Keep these low on public/free deployments.
CHAT_RATE_LIMIT_PER_MINUTE=6
CHAT_DAILY_LIMIT_PER_IP=40
CHAT_MAX_MESSAGE_CHARS=700
CHAT_MAX_HISTORY_ITEMS=4
CHAT_MAX_OUTPUT_TOKENS=420

# Local server port.
PORT=8787

# Admin password for deleting guestbook messages.
# Keep this in .env or your cloud host variables, not in profile.config.json.
GUESTBOOK_ADMIN_PASSWORD=

# Public production URL, used by sitemap.xml and robots.txt.
PUBLIC_SITE_URL=https://huangwenhao.com

# Optional custom file path for guestbook data.
# On a cloud host, point this to a mounted persistent disk if available.
GUESTBOOK_PATH=

# Optional shared persistent data directory for analytics and file fallbacks.
# On Render, set this to the mounted disk path, for example /var/data.
DATA_DIR=

# Upstash Redis for persistent guestbook storage (free tier: 10k requests/day).
# Sign up at https://upstash.com → create a Redis database → copy the REST URL and token.
# When configured, guestbook data survives redeploys. When not configured, falls back to local file.
REDIS_URL=
REDIS_TOKEN=
GUESTBOOK_REDIS_KEY=guestbook:messages
ANALYTICS_REDIS_KEY=analytics:visits
